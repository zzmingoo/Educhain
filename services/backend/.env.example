# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/educhain_db?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT 配置
JWT_SECRET=your-jwt-secret-key-at-least-512-bits-for-hs512

# 区块链服务配置
BLOCKCHAIN_SERVICE_URL=http://localhost:8000
BLOCKCHAIN_SERVICE_TIMEOUT=5000
BLOCKCHAIN_RETRY_ENABLED=true
BLOCKCHAIN_RETRY_MAX_ATTEMPTS=3
BLOCKCHAIN_RETRY_BACKOFF=1000
