# ============================================
# Git Attributes Configuration
# 用于统一跨平台的文件换行符和文件处理方式
# ============================================

# ============================================
# 1. 自动检测文本文件并规范化换行符
# ============================================
* text=auto

# ============================================
# 2. Shell 脚本 - 强制使用 LF (Unix 风格)
# ============================================
*.sh text eol=lf
*.bash text eol=lf

# Maven Wrapper 脚本
/services/backend/mvnw text eol=lf
mvnw text eol=lf

# ============================================
# 3. Windows 脚本 - 强制使用 CRLF
# ============================================
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# ============================================
# 4. 源代码文件 - 使用 LF
# ============================================
*.java text eol=lf
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.sql text eol=lf

# ============================================
# 5. 配置文件 - 使用 LF
# ============================================
*.md text eol=lf
*.txt text eol=lf
*.conf text eol=lf
*.config text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# ============================================
# 6. 二进制文件 - 不进行换行符转换
# ============================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.jar binary
*.war binary
*.ear binary
*.class binary
*.so binary
*.dll binary
*.dylib binary

# ============================================
# 7. 字体文件
# ============================================
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# ============================================
# 8. 视频和音频文件
# ============================================
*.mp4 binary
*.mp3 binary
*.mov binary
*.avi binary
*.webm binary

# ============================================
# 9. 数据库文件
# ============================================
*.db binary
*.sqlite binary
*.sqlite3 binary

# ============================================
# 10. 特殊处理 - 语言统计
# ============================================
# 排除某些文件不计入 GitHub 语言统计
*.min.js linguist-generated=true
*.min.css linguist-generated=true
package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true

# 标记文档目录
docs/** linguist-documentation=true

# 标记供应商代码
**/vendor/** linguist-vendored=true
**/node_modules/** linguist-vendored=true
